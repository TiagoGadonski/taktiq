{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "noEmit": true,
    
    // --- A PARTE IMPORTANTE ---
    "baseUrl": ".", // A base é a pasta 'frontend'
    "paths": {
      // Atalho para o pacote partilhado
      "@gymhero/shared": ["./packages/shared/src/index.ts"],
      
      // Atalho para a sua aplicação web
      "@/*": ["./apps/web/src/*"] 
    }
    // --- FIM DA CORREÇÃO ---
  },
  "exclude": ["node_modules"]
}