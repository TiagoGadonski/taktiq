{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "noEmit": true,
    "baseUrl": ".",
    //agora vai
    "paths": {
      "@gymhero/shared": ["./packages/shared/src/index.ts"],
      "@/*": ["./apps/web/src/*"]
    }
  },
  "exclude": ["node_modules"]
}