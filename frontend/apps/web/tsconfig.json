{
  "extends": "../../tsconfig.json", 
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    // Removemos os atalhos manuais que estávamos a adicionar
    "paths": {
      "@/*": ["./src/*"] 
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}