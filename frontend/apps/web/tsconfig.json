{
  // Herda TUDO (incluindo 'baseUrl' e 'paths') do ficheiro de base
  "extends": "../../tsconfig.json", 
  
  "compilerOptions": {
    // Apenas opções específicas do Next.js
    "plugins": [
      {
        "name": "next"
      }
    ]
    // A secção "paths" foi REMOVIDA daqui e movida para o ficheiro de base
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}