{
  // Diz a este ficheiro para herdar tudo do ficheiro base
  "extends": "../../tsconfig.json", 
  
  "compilerOptions": {
    // Mantém as opções específicas do Next.js
    "plugins": [
      {
        "name": "next"
      }
    ],
    // Adiciona o atalho específico da app (para "./src/*")
    // (O atalho @gymhero/shared já foi herdado)
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}